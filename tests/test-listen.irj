use std.test :open
use butterfly.core :open

;; Fibers inherit the parent's handler stack, so forks made inside
;; `with reactive` reach the same graph. Forks live in plain helper
;; fns — `spawn` inside a `with` body isn't a supported SM shape.

fn listen-and-store ::: Reactive Time
  => s result
  v := listen s
  reset result v

fn write-42-later ::: Reactive Time
  => s
  sleep 30
  reset s 42

fn cross-fiber-scenario ::: Reactive Time
  => s result
  f := spawn (-> listen-and-store s result)
  sleep 30
  reset s 42
  await f

fn run-cross-fiber ::: Reactive Time
  =>
  with reactive
    reset-graph ()
    s := signal 0
    result := signal 999
    cross-fiber-scenario s result
    assert-eq 42 (deref result)

fn listen-twice ::: Reactive Time
  => s out1 out2
  v1 := listen s
  reset out1 v1
  v2 := listen s
  reset out2 v2

;; scope auto-joins children at block exit — loop-subscriber pattern.
fn loop-scenario ::: Reactive Time
  => s out1 out2
  scope sc
    sc.fork (-> listen-twice s out1 out2)
    sleep 30
    swap s (x -> x + 1)
    sleep 30
    swap s (x -> x + 1)

fn run-loop-pattern ::: Reactive Time
  =>
  with reactive
    reset-graph ()
    s := signal 0
    o1 := signal 0
    o2 := signal 0
    loop-scenario s o1 o2
    assert-eq 1 (deref o1)
    assert-eq 2 (deref o2)

fn run-listen-or-timeout ::: Reactive Time
  =>
  with reactive
    reset-graph ()
    s := signal 0
    v := listen-or 40 s :gave-up
    assert-eq :gave-up v

fn write-7-later ::: Reactive Time
  => s
  sleep 30
  reset s 7

fn listen-or-scenario ::: Reactive Time
  => s
  f := spawn (-> write-7-later s)
  v := listen-or 500 s 999
  await f
  v

fn run-listen-or-value ::: Reactive Time
  =>
  with reactive
    reset-graph ()
    s := signal 0
    v := listen-or-scenario s
    assert-eq 7 v

results := #[
  (test "spawned fiber's listen sees a cross-fiber reset" run-cross-fiber)
  (test "scope: sequential listens = loop subscriber"     run-loop-pattern)
  (test "listen-or falls back after the deadline"         run-listen-or-timeout)
  (test "listen-or returns the value when it arrives"     run-listen-or-value)
]

summarize results
